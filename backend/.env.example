# Kinesis Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=spec_engine

# OpenRouter API (required for AI chat features)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o

# Local Whisper Model (faster-whisper for audio transcription)
# Options: tiny.en, base.en, small.en, medium.en, tiny, base, small, medium, large-v3, turbo
# .en models are English-only but more accurate for English
# Requires ffmpeg installed on system
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu

# OpenAI API Key (optional, only for embeddings/vector search)
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google OAuth Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# AWS S3 Storage (required for file uploads)
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# GitHub Personal Access Token (optional, for GitHub export)
GITHUB_PAT=ghp_your-github-pat

# Slack App Credentials (optional, for Slack integration)
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
